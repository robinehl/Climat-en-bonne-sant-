library(readxl)

Deces <- read_excel("Deces_causes.xlsx", col_types = c("numeric", "numeric", "text", "nu-meric"))

Pauvrete <- read_excel("Pauvrete_DEP.xlsx", col_types = c("numeric", "numeric", "numer-ic", "numeric"))

mortalite_cause_agg <- aggregate(DECES_NB ~ DEP + ANNEE, data = Deces, FUN = sum)
mortalite_departement <- aggregate(DECES_NB ~ DEP, data = mortalite_cause_agg, FUN = sum)

donnees_combinees <- merge(mortalite_departement, Pauvrete, by = "DEP")

donnees_combinees$taux_mortalite <- (donnees_combinees$DECES_NB / don-nees_combinees$POP) * 100000

donnees_combinees <- donnees_combinees[order(donnees_combinees$PAUV_60), ]
dep_median_eleve<- head(donnees_combinees, 10)
dep_median_faible <- tail(donnees_combinees, 10)

mortalite_riche <- mean(dep_median_eleve $taux_mortalite)
mortalité_pauvre <- mean(dep_median_faible $taux_mortalite)
