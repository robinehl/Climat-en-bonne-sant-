# Simplifier les données sur la couverture des arbres, ce qui permet d’économiser du temps de calcul
Arbres_Aire_metropolitaine_centralise <- st_centroid(Arbres_Aire_metropolitaine)
# Attributions des données sur la présence des arbres aux IRIS
Arbres_Iris_Metrop <- st_join(Arbres_Aire_metropolitaine_centralise, Iris_Metrop, join = st_intersects, left = FALSE)
# Calcul de la surface couverte par des arbres par IRIS
Arbres_surface_Metrop <- Arbres_Iris_Metrop %>% st_drop_geometry() %>% group_by(code_iris) %>% summarise(surface_totale_m2 = sum(superficie, na.rm = TRUE), nombre_zones = n())
Iris_superficie_Metrop <- Iris_Metrop %>% mutate(surface = st_area(geometrie))
Couverture_Arbres_Iris_Metrop <- left_join(Iris_superficie_Metrop, Arbres_surface_Metrop, by = "code_iris")
Couverture_Arbres_Iris_Metrop <- Couverture_Arbres_Iris_Metrop %>% mutate(taux_arbre = (surface_totale_m2 / surface) * 100)

# Importer les données sur le revenu médian et ajouter ces données à l’objet contenant les informations sur la couverture arborée
Revenu_France <- read_excel("Revenu 2021.xlsx")
Revenu_median_France <- Revenu_France %>% select(IRIS, DEC_MED21)
names(Revenu_median_France)[1] <- 'code_iris'
Donnees_territoire <- left_join(Couverture_Arbres_Iris_Metrop, Revenu_median_France, by = "code_iris")

# Suppression des champs vides résultant du secret statistique interdisant la diffusion des données sur le revenu pour les IRIS à faible nombre d’habitant·es
Donnees_territoire_prep <- Donnees_territoire %>% mutate(DEC_MED21 = ifelse(DEC_MED21 == "nd", NA, DEC_MED21))
Donnees_territoire_prep <- Donnees_territoire_prep %>% mutate(DEC_MED21 = ifelse(DEC_MED21 == "ns", NA, DEC_MED21))
Donnees_territoire_prep <- Donnees_territoire_prep %>% mutate(DEC_MED21 = as.numeric(DEC_MED21), taux_vegetation = as.numeric(taux_arbre))

# Calcul de la régression linéaire concernant la couverture arborée et le revenu médian par IRIS
regression <- lm(DEC_MED21 ~ taux_arbre, data = Donnees_territoire_prep)
summary(regression)
ggplot(Donnees_territoire_prep, aes(x= taux_arbre, y = DEC_MED21)) + geom_point() + geom_smooth(method = "lm", se = FALSE) + labs(title = "Relation entre revenu median et couverture arborée par Iris", x = "Couverture arborée", y = "Revenu médian")
