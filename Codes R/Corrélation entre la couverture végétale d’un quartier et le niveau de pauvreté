# Il s’agit du modèle de syntaxe permettant de calculer l’index pour une métropole

# S’il s’agit d’une métropole qui comprend de communes appartenant à différents départements, cette importation doit être répété pour les données de tous les départements concernés en remplaçant ‘00’ ou ‘000’ par le numéro du département
Arbres_00 <- st_read("000_Communes_COSIA_light.gpkg", layer = "couvert_arbore")
Arbres_00$superficie <- as.numeric(st_area(Arbres_00))

# La ligne de code est à exécuter uniquement pour l’importation des données du premier département sur le territoire de la métropole
Arbres_Aire_Metrop <- Arbres_00

# Ligne de code à exécuter à partir de l’importation pour un deuxième département sur le territoire de la métropole
Arbres_Aire_Metrop <- rbind(Arbres_Aire_Metrop, Arbres_00)

# Fin de l’importation, éventuellement répétée pour plusieurs départements

# Importation des contours des IRIS pour les départements concernés. Les numéros ‘00’ sont à remplacer par les numéros des départements sur lesquels s’étend la métropole
Iris_France <- st_read("contours-iris-pe.gpkg")
Iris_Aire_Metrop <- Iris_France %>% filter(grepl("^00|^00|^00", code_iris))
Iris_Aire_Metrop <- st_transform(Iris_Aire_Metrop, st_crs(Arbres_Aire_Metrop))

# Identification des noms des communes
communes_uniques <- Iris_Aire_Metrop %>% distinct(nom_commune) %>%   arrange(nom_commune)
write.xlsx(communes_uniques, "Membres_Metropole.xlsx", rowNames = FALSE)

# Création d’une liste des noms des communes composant la métropole. Cette liste doit être créé manuellement en indiquant les noms des communes entre les paranthèses
communes_Metrop <- c("A ", "B", "C")

# Identification des IRIS qui concernent une des communes de la métropole analysée
Iris_Metrop <- Iris_00 %>% filter(nom_commune %in% communes_Metrop)

