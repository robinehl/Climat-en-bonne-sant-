library(readxl)
Deces <- read_excel("Décès maladies appareil circulaire pour R.xlsx", col_types = c("numeric", "numeric", "text", "numeric"))
Pauvrete <- read_excel("Taux de pauvreté département pour R.xlsx", col_types = c("numeric", "numeric", "numeric", "numeric", "numeric", "numeric"))
mortalite_cause_agg <- aggregate(Deces ~ departement + annee, data = Deces, FUN = sum)


mortalite_departement <- aggregate(Deces ~ departement, data = mortalite_cause_agg, FUN = sum)

observations_departement <- merge(mortalite_departement, Pauvrete, by = "departement")

