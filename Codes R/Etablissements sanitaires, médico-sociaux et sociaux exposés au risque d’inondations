library(sf)
library(dplyr)
library(readxl)
library(dplyr)

## NB : Le code ne peut pas être exécuté d'un coup, car les résultats des calculs sont à lire manuellement après les différentes étapes

#########################################################
## Partie pour les calculs pour l'Hexagone et la Corse ##
#########################################################

Etablissements_loc <- st_read("Etablissements FI-NESS/ars_metropole_finess_annuaire_p.shp")
Zone_Inondable <- st_read("Zones inondables/n_carte_inond_s.shp")
Etablissements_loc <- st_as_sf(Etablissements_loc, sf_column_name = "geometry", crs = 4326)

# Exposition de l’ensemble des établissements FINESS

Exposition <- st_intersects(Etablissements_loc, Zone_Inondable, sparse = FALSE)
Etablissements_loc$Inondable <- as.integer(rowSums(Exposition) > 0)
Nb_Etablissements <- nrow(Etablissements_loc)

Nb_Etablissements_inondables <- sum(Etablissements_loc$Inondable)
Part_Etablissements_inondables <- (Nb_Etablissements_inondables / Nb_Etablissements) * 100

# Exposition des hôpitaux

Hopitaux_cat <- c("101", "355", "292", "131", "106", "109", "362", "122", "128", "129", "365", "156", "161", "366", "412", "415", "425", "430", "444")
Hopitaux_loc <- Etablissements_loc %>% filter(categorie %in% Hopitaux_cat)

Exposition_Hopitaux <- st_intersects(Hopitaux_loc, Zone_Inondable, sparse = FALSE)
Hopitaux_loc$Inondable <- as.integer(rowSums(Exposition_Hopitaux) > 0)

Nb_Hopitaux <- nrow(Hopitaux_loc)
Nb_Hopitaux_inondables <- sum(Hopitaux_loc$Inondable)
Part_Hopitaux_inondables <- (Nb_Hopitaux_inondables / Nb_Hopitaux) * 100

# Exposition des établissements d’accueil de personnes en situation de handicap

EANM_FAM_cat <- c("448", "449")
EANM_FAM_loc <- Etablissements_loc %>% filter(categorie %in% EANM_FAM_cat)
 
Exposition_EANM_FAM <- st_intersects(EANM_FAM_loc, Zone_Inondable, sparse = FALSE)
EANM_FAM_loc$Inondable <- as.integer(rowSums(Exposition_EANM_FAM) > 0)
 
Nb_EANM_FAM <- nrow(EANM_FAM_loc)
Nb_EANM_FAM_inondables <- sum(EANM_FAM_loc$Inondable)
Part_EANM_FAM_inondables <- (Nb_EANM_FAM_inondables / Nb_EANM_FAM) * 100

# Exposition des centres d’action médico-sociale précoce

CAMSP_cat <- c("190")
CAMSP_loc <- Etablissements_loc %>% filter(categorie %in% CAMSP_cat)

Exposition_CAMSP <- st_intersects(CAMSP_loc, Zone_Inondable, sparse = FALSE)
CAMSP_loc$Inondable <- as.integer(rowSums(Exposition_CAMSP) > 0)

Nb_CAMSP <- nrow(CAMSP_loc)
Nb_CAMSP_inondables <- sum(CAMSP_loc$Inondable)
Part_CAMSP_inondables <- (Nb_CAMSP_inondables / Nb_CAMSP) * 100

# Exposition des EHPAD

EHPAD_cat <- c("500")
EHPAD_loc <- Etablissements_loc %>% filter(categorie %in% EHPAD_cat)

Exposition_EHPAD <- st_intersects(EHPAD_loc, Zone_Inondable, sparse = FALSE)
EHPAD_loc$Inondable <- as.integer(rowSums(Exposition_EHPAD) > 0)

Nb_EHPAD <- nrow(EHPAD_loc)
Nb_EHPAD_inondables <- sum(EHPAD_loc$Inondable)
Part_EHPAD_inondables <- (Nb_EHPAD_inondables / Nb_EHPAD) * 100

# Nombre de lits des hôpitaux exposés aux inondations

Capacités <- read_excel("Lits d'hôpitaux par établissement.xlsx")
Etablissements_loc <- left_join(Etablissements_loc, Capacités, by = c("finess" = "FINESS"))
Lits_Hopitaux_inondables <- sum(Etablissements_loc$LITS_Ensemble[Etablissements_loc$Inondable == 1], na.rm = TRUE)


