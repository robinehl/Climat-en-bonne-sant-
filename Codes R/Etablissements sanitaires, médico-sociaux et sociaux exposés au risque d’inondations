## Guadeloupe

# Importation données
Etablissements <- read_delim("etalab-cs1100507-stock-20260311-0343.csv", delim = ";", escape_double = FALSE, trim_ws = TRUE)
shp_files <- list.files(
  path = "Guadeloupe",
  pattern = "\\.shp$",
  recursive = TRUE,
  full.names = TRUE
) 
zones_inondables <- map_dfr(shp_files, read_sf, .id = "source") 
# Contrôler la projection des zones inondables pour pouvoir adapter les coordonnées des établissements des établissements de santé en fonction
st_crs(zones_inondables)

# Filtrage des établissements pour le territoire
etablissements_Guadeloupe <- Etablissements %>% filter(`15` == "GUADELOUPE")
etablissements_geo_Guadeloupe <- st_as_sf(etablissements_Guadeloupe, coords = c("Coordo_X", "Coordo_Y"), crs = 4559)

Exposition <- st_intersects(etablissements_geo_Guadeloupe, zones_inondables, sparse = FALSE)
etablissements_geo_Guadeloupe$inondable <- as.integer(rowSums(Exposition) > 0)
Etablissements_inondables_Guadeloupe <- nrow(etablissements_geo_guadeloupe)

# EHPAD
EHPAD_guadeloupe <- etablissements_geo_guadeloupe %>% filter(`19` == 500) # Catégorie 500 EHPHAD
Exposition <- st_intersects(EHPAD_guadeloupe, zones_inondables, sparse = FALSE)
EHPAD_guadeloupe$inondable <- as.integer(rowSums(Exposition) > 0)
Nb_EHPAD <- nrow(EHPAD_guadeloupe)
Nb_EHPAD_inondables <- sum(EHPAD_guadeloupe$inondable)
Part_EHPAD_inondables <- (Nb_EHPAD_inondables / Nb_EHPAD) * 100

